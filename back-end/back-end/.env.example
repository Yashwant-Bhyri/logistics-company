# Copy this file to .env alongside app.py / smoke_ai.py, then fill OPENROUTER_API_KEY.
# app.py loads .env automatically (python-dotenv). Verify with:
#   python smoke_ai.py
#
JWT_SECRET_KEY=change-me-long-random-secret
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=LOGISTICS_COMPANY

OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Automatic fallback model when the primary model call fails
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat-v3-0324
# Optional second fallback if first fallback is unavailable
OPENROUTER_FALLBACK_MODEL_2=
# Default client behavior bypasses env HTTP(S)_PROXY for OpenRouter calls.
# Set to 1 only if your network requires using the configured proxy.
OPENROUTER_USE_ENV_PROXY=0

# Optional (OpenRouter request metadata)
# OPENROUTER_HTTP_REFERER=http://localhost:3000
# OPENROUTER_APP_TITLE=Logistics Company
